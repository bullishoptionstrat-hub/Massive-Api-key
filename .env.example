# Massive API Key (sign up at https://massive.com/dashboard/api-keys)
# Massive (formerly Polygon.io) provides real-time futures data via REST and WebSocket.
MASSIVE_API_KEY=your_massive_api_key_here

# Alpha Vantage API Key — optional free-tier fallback
# Get a free key at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Refresh interval in seconds for the terminal display (default: 5)
TERMINAL_REFRESH_SECONDS=5

# Comma-separated list of futures tickers to track (optional, uses defaults when omitted)
# Massive format: ES1!, NQ1!, CL1! ...
# Yahoo Finance format: ES=F, NQ=F, CL=F ...
FUTURES_TICKERS=ES1!,NQ1!,YM1!,RTY1!,CL1!,GC1!,SI1!,ZB1!
